# ===========================
# Docker 部署环境变量配置
# 复制此文件为 .env 并修改
# cp .env.docker .env
# ===========================

# 数据库配置
DB_USERNAME=postgres
DB_PASSWORD=123456
DB_DATABASE=jiaoyi

# JWT 配置
JWT_SECRET=your-jwt-secret-change-me
JWT_EXPIRATION=7d

# 支付宝配置（生产环境必填）
ALIPAY_APPID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# 微信支付配置（生产环境必填）
WECHAT_MCHID=
WECHAT_API_KEY=
WECHAT_CERT_PATH=
