# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_DATABASE=yaozhuanzhuan

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# WebSocket
WS_NAMESPACE=/ws

# 支付宝配置
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key
ALIPAY_NOTIFY_URL=http://www.mufend.com/api/payment/alipay/notify

# 微信支付配置（V2 + V3 双模式，自动选择）
WECHAT_APP_ID=your_wechat_app_id
WECHAT_MCH_ID=your_wechat_mch_id
WECHAT_API_KEY=your_wechat_api_v2_key
WECHAT_API_V3_KEY=your_wechat_apiv3_key
WECHAT_CERT_SERIAL_NO=your_wechat_cert_serial_no
WECHAT_PUBLIC_KEY_ID=your_wechat_public_key_id
WECHAT_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WECHAT_NOTIFY_URL=http://mufend.com/api/payment/wechat/notify
